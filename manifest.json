{
  "manifest_version": 3,
  "name": "My Browser Activity",
  "version": "1.0.0",

  "permissions": [
    "tabs",
    "activeTab"
  ],

  "background": {
    "scripts": ["dist/index.js"],
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_icon": "assets/icons/icon.png",
    "default_title": "My Browser Activity"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "dist/**/*.{js,css}"
      ],
      "matches": [ "*://*/*" ]
    }
  ]
}